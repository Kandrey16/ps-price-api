model Game {
  id            String        @id @default(uuid())
  slug          String    @unique
  title         String
  rating        Int?
  genre         String?
  publisher     String?
  isFreeToPlay  Boolean?      @default(false)
  releaseDate   DateTime?
  releaseStatus ReleaseStatus @default(RELEASED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  GameLanguageSupport GameLanguageSupport[]
  GameImage           GameImage[]
  PsPlus              PsPlus[]
  GameEdition         GameEdition[]

  @@map("games")
}

enum ReleaseStatus {
  RELEASED
  PREORDER
  COMING_SOON
}

enum Platform {
  PS4
  PS5
  PS4_PS5
  VR
  VR2
}

enum ImageType {
  SCREENSHOT
  MAIN
  BACKGROUND
  COVER
  ARTBOOK
  ICON
  TRAILER
}

enum LanguageType {
  VOICE
  SUBTITLE
}

enum PsPlusType {
  ESSENTIAL
  EXTRA
  PREMIUM
}

model Language {
  id   Int    @id @default(autoincrement())
  code String @unique @db.VarChar(10) // Ограничим длину
  name String @db.VarChar(100)

  GameLanguageSupport GameLanguageSupport[]

  @@map("languages")
}

model GameLanguageSupport {
  id           Int          @id @default(autoincrement())
  gameId       String
  languageId   Int
  languageType LanguageType
  game         Game         @relation(fields: [gameId], references: [id], onDelete: Cascade)
  language     Language     @relation(fields: [languageId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([gameId, languageId, languageType])
  @@index([gameId])
  @@map("game_language_support")
}

model GameImage {
  id     Int       @id @default(autoincrement())
  url    String?   @db.Text
  type   ImageType @default(SCREENSHOT)
  gameId String
  game   Game      @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([url, gameId])
  @@index([gameId])
  @@map("game_images")
}

model PsPlus {
  id     String     @id @default(uuid())
  gameId String
  type   PsPlusType @default(ESSENTIAL)
  game   Game       @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([gameId, type])
  @@index([gameId])
  @@map("ps_plus_offers")
}
